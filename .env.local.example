# Sanity Configuration
# Get these values from sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Resend Email API (for contact form)
RESEND_API_KEY=your_resend_api_key_here

# Calendly Integration
# Replace these with your actual Calendly scheduling page URLs
# You can create different event types for each service in your Calendly account

# Emergency Services (2-hour response time)
NEXT_PUBLIC_CALENDLY_EMERGENCY_URL=https://calendly.com/your-account/emergency-service

# Standard Services
NEXT_PUBLIC_CALENDLY_PLUMBING_URL=https://calendly.com/your-account/plumbing-consultation
NEXT_PUBLIC_CALENDLY_ELECTRICAL_URL=https://calendly.com/your-account/electrical-consultation
NEXT_PUBLIC_CALENDLY_HVAC_URL=https://calendly.com/your-account/hvac-consultation
NEXT_PUBLIC_CALENDLY_CARPENTRY_URL=https://calendly.com/your-account/carpentry-consultation
NEXT_PUBLIC_CALENDLY_PAINTING_URL=https://calendly.com/your-account/painting-consultation
NEXT_PUBLIC_CALENDLY_FLOORING_URL=https://calendly.com/your-account/flooring-consultation
NEXT_PUBLIC_CALENDLY_INSTALLATION_URL=https://calendly.com/your-account/installation-consultation
NEXT_PUBLIC_CALENDLY_MAINTENANCE_URL=https://calendly.com/your-account/maintenance-consultation

# General Consultation (for clients who aren't sure which service they need)
NEXT_PUBLIC_CALENDLY_CONSULTATION_URL=https://calendly.com/your-account/general-consultation
